void monitor_pid(){
    int f_pid = open(".monitor_pid", O_CREAT | O_RDWR | O_APPEND, 0664);
    if (f_pid == -1) {
        perror("Failed to open/create .monitor_pid\n");
        exit(EXIT_FAILURE);
    }

    pid_t current_pid;

    current_pid = getpid();

    //write the structure to the file
    if (write(f_pid, current_pid) {
