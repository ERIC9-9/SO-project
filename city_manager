#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <stdbool.h>
#include <string.h>

typedef struct Report{
    char districtID[40];
    int reportID;
    char name[40];
    float lat,lng;
    char category[40];
    int severity;
    time_t timestamp;
    char text[100];
}Report;

//parsing the arguments from the command line that represent the role
bool parseRole(bool *role, char *func, char *value){
    if(strcmp(func,"--role") != 0) return false;
    if(strcmp(value,"manager") == 0) *role = true;
    else if(strcmp(value,"inspector") == 0) *role = false;
    else return false;

    return true;
}

//parsing --user
bool parseUser(char *user, char *func, char *value){
    if(strcmp(func,"--user") != 0) return false;

    strcpy(user,value);

    return true;
}

//determining the function that is called
int functionDet(char *func){
    switch (func){
        case "--add":
            return 1;
        case "--list":
            return 2;
        case "--view":
            return 3;
        case "--remove_report":
            return 4;
        case "--update_threshold":
            return 5;
        case "--filter":
            return 6;
        default :
            return 7;
    }
}

int main(int argc, char *argv[]){
    if(argc == 1){
        printf("No arguments were delivered in command line1\n");
        exit(-1);
    }

    int indexArgc = 1;
    Report current;
    bool role;//1 - manager, 0 - inspector
    if(indexArgc+1 < argc){
        if(!parseRole(&role,argv[indexArgc],argv[indexArgc+1])){
            printf("The role couldn't be parsed!\n");
            exit(-1);
        }
    } else{
        printf("Don't have arguments for role\n");
        exit(-1);
    }

    indexArgc+=2;
    if(indexArgc+1 < argc){
        if(!parseUser(current.name,argv[indexArgc],argv[indexArgc+1])){
            printf("The user couldn't be parsed!\n");
            exit(-1);
        }
    } else{
        printf("Don't have arguments for user\n");
        exit(-1);
    }

    indexArgc+=2;

    if(indexArgc < argc){
        if(functionDet(argv[indexArgc]) > 6 || functionDet(argv[indexArgc]) < 1){
            printf("The function couldn't be parsed!\n");
            exit(-1);
        }
    } else{
        printf("Don't have arguments for user\n");
        exit(-1);
    }
    return 0;
}
